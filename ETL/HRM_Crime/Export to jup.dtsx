              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select c.EventDate
       ,cal.Year
       ,cal.Month
       ,cal.Day
       ,case cal.IsWeekday
            when 1 then 'True'
            else 'False'
            end as IsWeekday
       ,Crime_Classification_Code
       ,Crime_Severity_Level 
       ,Crime_Category
       ,l.location
       ,count(*) as 'Total_Crimes'
       ,l.x 
       ,l.y 
from fact.Crime c
inner join dim.Location l 
on c.Location_ID = l.Location_ID
inner join dim.Crime cr 
ON c.Crime_ID = cr.Crime_ID
inner join dim.Calendar as cal
on cal.DateValue = c.EventDate
group by c.EventDate
       ,cal.Year
       ,cal.Month
       ,cal.Day
       ,case cal.IsWeekday
            when 1 then 'True'
            else 'False'
            end 
       ,Crime_Classification_Code
       ,Crime_Severity_Level 
       ,Crime_Category
       ,l.location
       ,l.x 
       ,l.y</property>
                <property
