                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
          l.LOCATION
         ,cal.Year
         ,cal.MonthShort
         ,cal.DayShort
         ,case cal.IsWeekday
               when 1 then 'TRUE'
               else 'False'
               end as IsWeekday
        ,SUM(c.Crime_Count) AS Total_Crimes
FROM fact.Crime c
inner join dim.Location as l
on l.Location_ID = c.Location_ID
inner join dim.Calendar as cal 
on cal.DateValue = c.EventDate
GROUP BY l.LOCATION
         ,cal.Year
         ,cal.MonthShort
         ,cal.DayShort
         ,cal.IsWeekday</property>
