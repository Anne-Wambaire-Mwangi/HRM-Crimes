                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select  el.Event_ID
       ,EVT_RT as 'Event_Reporting_Type'
       ,case 
             WHEN Evt_RT = 'GO' Then 'General Occurence'
             end as 'Event_Type_Description'
from stg.HalifaxCrime as hc
left outer join lup.Event_ID as el
on el.Event_Name = hc.EVT_RT
where el.Event_ID not in (select Event_ID from dim.Event)
group by  el.Event_ID
          ,EVT_RT 
          ,case 
                 WHEN Evt_RT = 'GO' Then 'General Occurence'
                 end</property>
