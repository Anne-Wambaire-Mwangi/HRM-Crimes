       ,x
       ,y
from stg.HalifaxCrime
left outer join lup.location_ID as l
on l.Location_Name = concat_ws('-',location,x,y)
where l.Location_ID not in (select Location_ID from dim.location)
group by l.Location_ID
       ,LOCATION
       ,x
       ,y</property>
