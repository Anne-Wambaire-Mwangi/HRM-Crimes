                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select lc.Crime_ID
      ,RUCR as 'Crime_Classification_Code'
      ,RUCR_EXT_D as 'Crime_Category'
      ,Concat_ws('-',RUCR,RUCR_EXT_D) as 'Crime_Type'  
      ,CASE RUCR
            WHEN 1410 THEN 'Aggravated Assault'             
            WHEN 1420 THEN 'weapon or bodily harm Assault'
            WHEN 1430 THEN 'Common Assault'
            WHEN 1460 THEN 'Assault Against Peace/Public Officer'
            WHEN 1461 THEN 'Aggravated/weapon variant against peace officer'
            WHEN 1610 THEN 'Robbery With Threat/Force' 
            WHEN 2120 THEN 'Break &amp; Enter Premises (Res/Comm)'
            WHEN 2132 THEN 'Theft from Vehicle – Parts/Accessories – Over $5,000'
            WHEN 2142 THEN 'Theft from Vehicle – Contents/General - $5,000 or Under'
            WHEN 2135 THEN 'Stolen Vehicle'
            ELSE 'Other/Unknown '
            END AS Crime_Subcategory
    ,CASE 
        WHEN RUCR IN (1410,1460, 1461, 1610) THEN 'High'
        WHEN RUCR IN (1420, 1430, 2120, 2135) THEN 'Medium'
        WHEN RUCR IN (2132, 2142) THEN 'Low'
        ELSE 'Unknown'
    END AS Crime_Severity_Level

from stg.HalifaxCrime
left outer join lup.Crime_ID as lc
on Concat_ws('-',RUCR,RUCR_EXT_D) = lc.Crime_Name
where lc.Crime_ID not in(select  Crime_ID from dim.Crime)
group by 
       lc.Crime_ID
      ,RUCR 
      ,RUCR_EXT_D 
      ,Concat_ws('-',RUCR,RUCR_EXT_D)  
      ,CASE RUCR
            WHEN 1410 THEN 'Aggravated Assault'             
            WHEN 1420 THEN 'weapon or bodily harm Assault'
            WHEN 1430 THEN 'Common Assault'
            WHEN 1460 THEN 'Assault Against Peace/Public Officer'
            WHEN 1461 THEN 'Aggravated/weapon variant against peace officer'
            WHEN 1610 THEN 'Robbery With Threat/Force' 
            WHEN 2120 THEN 'Break &amp; Enter Premises (Res/Comm)'
            WHEN 2132 THEN 'Theft from Vehicle – Parts/Accessories – Over $5,000'
            WHEN 2142 THEN 'Theft from Vehicle – Contents/General - $5,000 or Under'
            WHEN 2135 THEN 'Stolen Vehicle'
            ELSE 'Other/Unknown '
            END 
    ,CASE 
        WHEN RUCR IN (1410,1460, 1461, 1610) THEN 'High'
        WHEN RUCR IN (1420, 1430, 2120, 2135) THEN 'Medium'
        WHEN RUCR IN (2132, 2142) THEN 'Low'
        ELSE 'Unknown'
    END 

order by Crime_ID asc</property>
