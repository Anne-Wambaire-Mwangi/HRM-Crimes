                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT  c.EventDate
        ,cal.Year
        ,cal.Quarter
        ,cal.MonthShort
        ,cal.Week
        ,cal.DayShort
        ,SUM(c.Crime_Count) AS Total_Crimes
FROM fact.Crime c
inner join dim.Calendar as cal
on cal.DateValue = c.EventDate
GROUP BY c.EventDate
        ,cal.Year
        ,cal.Quarter
        ,cal.MonthShort
        ,cal.Week
        ,cal.DayShort</property>
