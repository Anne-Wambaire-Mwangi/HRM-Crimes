                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select  Crime_Classification_Code
       ,cr.Crime_Category
       ,cr.Crime_Subcategory
      
      ,sum(c.crime_count) as 'Total_Crimes'
from fact.Crime as c
inner join dim.Crime as cr
on c.Crime_ID = cr.Crime_ID
group by  Crime_Classification_Code
         ,cr.Crime_Category
         ,cr.Crime_Subcategory</property>
